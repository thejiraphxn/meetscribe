generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatarUrl     String?
  // Google sign-in users have a googleId; email/password users have a passwordHash.
  googleId      String?        @unique
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  projects      Project[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete marker: DELETE /projects/:id sets this rather than removing the row.
  deletedAt   DateTime?
  sessions    Session[]

  @@index([userId])
}

model Session {
  id              String              @id @default(cuid())
  localId         String              @unique // SQLite UUID generated on device
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String?
  mode            TranscriptionMode
  durationSeconds Int
  language        String              @default("th")
  startedAt       DateTime
  endedAt         DateTime
  notes           String? // markdown from LLM
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  segments        TranscriptSegment[]
  actionItems     ActionItem[]

  @@index([projectId])
}

model TranscriptSegment {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence   Int
  startSec   Float
  endSec     Float?
  text       String
  speaker    String?
  confidence Float?
  isFinal    Boolean  @default(true)

  @@index([sessionId, sequence])
}

model ActionItem {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text      String
  assignee  String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId])
}

enum TranscriptionMode {
  realtime
  batch
}
