# ─────────────────────────────────────────────────────────────────────────
# MeetScribe backend — environment
# Copy to `.env` and fill in. Validated by src/lib/env.ts (zod) at startup;
# a missing/invalid value aborts the process with a clear message.
# ─────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
#   Local Docker (matches README): docker run -e POSTGRES_USER=meetscribe \
#     -e POSTGRES_PASSWORD=meetscribe -e POSTGRES_DB=meetscribe -p 5432:5432 postgres:16
#   On Render this is injected automatically from the managed database.
DATABASE_URL=postgresql://meetscribe:meetscribe@localhost:5432/meetscribe

# JWT signing secrets (required, each ≥ 32 chars).
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-32+-random-bytes-hex
JWT_REFRESH_SECRET=replace-with-another-32+-random-bytes-hex

# Google OAuth credentials (required by the schema, even for local email/password
# dev — any non-empty placeholder is fine if you only use /auth/register + login).
# Real values come from Google Cloud Console → Credentials → OAuth client (Web).
# Authorized redirect URI must be: {BACKEND_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Public base URL of THIS backend (required, used to build the OAuth redirect URI).
#   Local:      http://localhost:3000
#   Production: https://meetscribe-api.onrender.com
BACKEND_URL=http://localhost:3000

# Where the backend deep-links the desktop app after OAuth (default: meetscribe://).
FRONTEND_URL=meetscribe://

# HTTP port (default 3000).
PORT=3000

# development | production | test (default development).
# NOTE: dev-only routes (/auth/dev-login) are disabled when NODE_ENV=production.
NODE_ENV=development
