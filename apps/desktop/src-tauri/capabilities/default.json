{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the bar and panel windows",
  "windows": ["bar", "panel", "caption"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:event:default",
    "core:app:allow-version",
    "shell:allow-open",
    "deep-link:default"
  ]
}
