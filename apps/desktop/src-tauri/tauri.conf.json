{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeetScribe",
  "version": "0.1.0",
  "identifier": "com.meetscribe.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "bar",
        "url": "index.html#/bar",
        "title": "MeetScribe",
        "width": 480,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "panel",
        "url": "index.html#/panel",
        "title": "MeetScribe",
        "width": 720,
        "height": 560,
        "visible": false,
        "minWidth": 480,
        "minHeight": 400
      },
      {
        "label": "caption",
        "url": "index.html#/caption",
        "title": "MeetScribe Captions",
        "width": 600,
        "height": 130,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["meetscribe"]
      }
    }
  }
}
