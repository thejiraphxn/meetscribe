# ─────────────────────────────────────────────────────────────────────────
# MeetScribe desktop (Vite) — environment
# Copy to `.env`. Only VITE_*-prefixed vars are exposed to the frontend.
# Vite reads these at dev-server START / build time (restart after changes).
# ─────────────────────────────────────────────────────────────────────────

# Base URL of the backend API the app talks to (required).
#   Local:      http://localhost:3000
#   Production: https://meetscribe-api.onrender.com
VITE_BACKEND_URL=http://localhost:3000

# Transcription / summarisation API keys are NOT set here — the user enters them
# in the app's Settings (⚙); they are stored locally and sent to the sidecar at
# runtime. The desktop env only needs VITE_BACKEND_URL.
