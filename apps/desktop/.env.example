# ─────────────────────────────────────────────────────────────────────────
# MeetScribe desktop (Vite) — environment
# Copy to `.env`. Only VITE_*-prefixed vars are exposed to the frontend.
# Vite reads these at dev-server START / build time (restart after changes).
# ─────────────────────────────────────────────────────────────────────────

# Base URL of the backend API the app talks to (required).
#   Local:      http://localhost:3000
#   Production: https://meetscribe-api.onrender.com
VITE_BACKEND_URL=http://localhost:3000

# Transcription API keys.
# NOTE: in the current setup the Python sidecar reads its own keys from
# `sidecar/.env` (DEEPGRAM_API_KEY / GROQ_API_KEY). These VITE_ vars are kept
# for the spec's "pass keys via cmd:start" path — set them here too if/when the
# desktop forwards keys to the sidecar. They are NEVER sent to the backend.
VITE_DEEPGRAM_API_KEY=
VITE_GROQ_API_KEY=
