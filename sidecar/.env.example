# ─────────────────────────────────────────────────────────────────────────
# MeetScribe sidecar — environment
# Copy to `.env` and fill in. Validated by config.py (pydantic) at startup.
# The sidecar BOOTS without API keys (the WebSocket server starts), but a
# `start` command fails loudly if the key for the requested mode is missing.
# ─────────────────────────────────────────────────────────────────────────

# ── Transcription API keys ────────────────────────────────────────────────
# DEEPGRAM_API_KEY → required for realtime mode (Deepgram Nova-2 streaming)
# GROQ_API_KEY     → required for batch mode (Groq Whisper transcription)
# These keys live ONLY here / in the desktop env — never sent to the backend.
# (Summarisation no longer needs a Groq key — it runs on local Ollama.)
DEEPGRAM_API_KEY=
GROQ_API_KEY=

# ── Transcription models (cloud) ──────────────────────────────────────────
DEEPGRAM_MODEL=nova-2
GROQ_WHISPER_MODEL=whisper-large-v3

# ── Summarisation LLM via Ollama (local) ──────────────────────────────────
# Start Ollama and pull a model first:  ollama pull llama3.1
# qwen2.5 tends to handle Thai better:  ollama pull qwen2.5  (then OLLAMA_MODEL=qwen2.5)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── WebSocket server (desktop ↔ sidecar) ──────────────────────────────────
MEETSCRIBE_WS_HOST=127.0.0.1
MEETSCRIBE_WS_PORT=8765

# ── Local storage + native helper ─────────────────────────────────────────
# SQLite file (mirrors the Postgres schema). Default: ~/.meetscribe/local.db
MEETSCRIBE_DB_PATH=~/.meetscribe/local.db
# Compiled Swift system-audio helper. Default: ../native/systemtap
# If missing, the sidecar falls back to microphone-only capture.
MEETSCRIBE_SYSTEMTAP_PATH=../native/systemtap
